# Copy to .env.local and set one or more DBOS system database URLs.
# Use DBOS_DATABASE_<Name>=... (Name = label in the UI).
DBOS_DATABASE_MyPage=postgresql://postgres:postgres@localhost:5432/my_page_dbos

# Optional: admin secret. If set, users must enter this secret to access the dashboard. If empty, login is disabled.
ADMIN_SECRET=your-secret-here

# Optional: custom workflow filters by input fields. Comma-separated list of field names to match.
DBOS_CUSTOM_FILTER_USER_ID=userId,user_id
DBOS_CUSTOM_FILTER_ORDER=orderId,order_id,order
